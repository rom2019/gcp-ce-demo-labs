# terraform.tfvars.example
# 실제 사용 시 이 파일을 terraform.tfvars 로 복사 후 값을 채우세요.
# terraform.tfvars 는 .gitignore에 반드시 추가하세요.

project_id          = "your-gcp-project-id"
region              = "asia-northeast3"
litellm_master_key  = ""  # 원하는 값으로 설정
anthropic_api_key   = ""   # Anthropic 사용 시 입력
openai_api_key      = ""   # OpenAI 사용 시 입력
allow_public_access = false  # demo 목적이면 true
